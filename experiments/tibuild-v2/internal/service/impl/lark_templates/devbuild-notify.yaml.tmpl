msg_type: interactive
card:
  config:
    wide_screen_mode: true
  header:
    template: {{ StatusColor .Status }}
    title:
      content: "{{ StatusEmoji .Status }} DevBuild #{{ .BuildID }} - {{ .Product }} {{ .Version }}"
      tag: plain_text
  elements:
    - tag: markdown
      content: |-
        **Status:** `{{ .Status }}`
        **Product:** {{ .Product }}
        **Version:** {{ .Version }}
        **Platform:** {{ .Platform }}
        **Git Ref:** {{ .GitRef }}
        **Created By:** {{ .CreatedBy }}

    {{- if .GithubRepo }}
    - tag: markdown
      content: |-
        **Repository:** [{{ .GithubRepo }}](https://github.com/{{ .GithubRepo }})
    {{- end }}

    {{- if .PipelineRuns }}
    - tag: hr
    - tag: markdown
      content: |-
        **Pipeline Runs:**
        {{- range .PipelineRuns }}
        - **{{ .Name }}:** {{ .Status }}
        {{- end }}
    {{- end }}

    {{- if .PipelineRuns }}
    - tag: action
      actions:
        {{- range .PipelineRuns }}
        {{- if .URL }}
        - tag: button
          text:
            content: "View {{ .Name }}"
            tag: plain_text
          url: "{{ .URL }}"
          type: primary
        {{- end }}
        {{- end }}
    {{- end }}

    {{- if .ErrMsg }}
    - tag: hr
    - tag: markdown
      content: |-
        **Error:**
        ```text
        {{ .ErrMsg }}
        ```
    {{- end }}
