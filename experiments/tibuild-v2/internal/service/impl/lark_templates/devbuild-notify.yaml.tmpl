config:
  wide_screen_mode: true
header:
  template: {{ StatusColor .Status }}
  title:
    content: "{{ StatusEmoji .Status }} DevBuild #{{ .BuildID }} - {{ .Product }} {{ .Version }}"
    tag: plain_text
elements:
  - tag: div
    fields:
      {{- with .Status }}
      - is_short: false
        text:
          tag: lark_md
          content: "**Status:**\t{{ StatusEmoji . }}{{ . }}"
      {{- end }}
      {{- with .CreatedBy }}
      - is_short: false
        text:
          tag: lark_md
          content: "🧑‍💻 **Created By:**\t{{ . }}"
      {{- end }}
      {{- with .CreatedAt }}
      - is_short: false
        text:
          tag: lark_md
          content: "🛫 **Created at:**\t{{ . }}"
      {{- end }}
      {{- with .CompletedAt }}
      - is_short: false
        text:
          tag: lark_md
          content: "🛬 **Completed time:**\t{{ . }}"
      {{- end }}
  - tag: hr
  - tag: markdown
    content: |-
      **Request:**
      - **Product:** {{ .Product }}
      - **Version:** {{ .Version }}
      - **Platform:** {{ .Platform }}
      {{- with .GithubRepo }}
      - **Repository:** [{{ . }}](https://github.com/{{ . }})
      {{- end }}
      {{- $gitRefURL := GitRefURL .GitRef .GithubRepo }}
      {{- if $gitRefURL }}
      - **Git Ref:** [{{ .GitRef }}]({{ $gitRefURL }})
      {{- else }}
      - **Git Ref:** {{ .GitRef }}
      {{- end }}

  {{- if or .GitSha .Images .Binaries }}
  - tag: hr
  - tag: markdown
    content: |-
      **Build Report**
      {{- if .GitSha }}
      {{- $shaURL := GitRefURL .GitSha $.GithubRepo }}
      {{- if $shaURL }}
      - **Git SHA:** [{{ .GitSha }}]({{ $shaURL }})
      {{- else }}
      - **Git SHA:** {{ .GitSha }}
      {{- end }}
      {{- end }}
      {{- if .Images }}
      - **Docker Images:**
        ```YAML
        {{- range .Images }}
        - {{ .URL }}
        {{- end }}
        ```
      {{- end }}
      {{- if .Binaries }}
      - **Binaries:**
        ```YAML
        {{- range .Binaries }}
        - {{ .OciReference }}
        {{- end }}
        ```
      {{- end }}
  {{- end }}

  {{- if .PipelineRuns }}
  - tag: hr
  - tag: markdown
    content: |-
        **Pipeline Runs:**
        {{- range .PipelineRuns }}
        - {{ PipelineStatusEmoji .Status }} **{{ .Name }}:** [{{ .Status }}]({{ .URL }})
        {{- end }}
  {{- end }}

  {{- if .ErrMsg }}
  - tag: hr
  - tag: markdown
    content: |-
      **Error:**
      ```text
      {{ .ErrMsg }}
      ```
  {{- end }}
