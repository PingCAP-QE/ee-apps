config:
  wide_screen_mode: true
header:
  template: {{ StatusColor .Status }}
  title:
    content: "{{ StatusEmoji .Status }} DevBuild #{{ .BuildID }} - {{ .Product }} {{ .Version }}"
    tag: plain_text
elements:
  - tag: markdown
    content: |-
      **Status:** {{ StatusEmoji .Status }} {{ .Status }}
      **Product:** {{ .Product }}
      **Version:** {{ .Version }}
      **Platform:** {{ .Platform }}
      **Created At:** `{{ .CreatedAt }}`
      {{- if .CompletedAt }}
      **Completed At:** `{{ .CompletedAt }}`
      {{- end }}
      {{- $gitRefURL := GitRefURL .GitRef .GithubRepo }}
      {{- if $gitRefURL }}
      **Git Ref:** [{{ .GitRef }}]({{ $gitRefURL }})
      {{- else }}
      **Git Ref:** {{ .GitRef }}
      {{- end }}
      **Created By:** {{ .CreatedBy }}

  {{- if .GithubRepo }}
  - tag: markdown
    content: |-
      **Repository:** [{{ .GithubRepo }}](https://github.com/{{ .GithubRepo }})
  {{- end }}

  {{- if or .GitSha .Images .Binaries }}
  - tag: hr
  - tag: markdown
    content: |-
      **Build Report**
      {{- if .GitSha }}
      **Git SHA:** `{{ .GitSha }}`
      {{- end }}
      {{- if .Images }}
      - **Docker Images:**
        {{- range .Images }}
        - `{{ .URL }}` ({{ .Platform }})
        {{- end }}
      {{- end }}
      {{- if .Binaries }}
      - **Binaries:**
        {{- range .Binaries }}
        - `{{ .OciReference }}`
        {{- end }}
      {{- end }}
  {{- end }}

  {{- if .PipelineRuns }}
  - tag: hr
  - tag: markdown
    content: |-
        **Pipeline Runs:**
        {{- range .PipelineRuns }}
        - {{ PipelineStatusEmoji .Status }} **{{ .Name }}:** [{{ .Status }}]({{ .URL }})
        {{- end }}
  {{- end }}

  {{- if .ErrMsg }}
  - tag: hr
  - tag: markdown
    content: |-
      **Error:**
      ```text
      {{ .ErrMsg }}
      ```
  {{- end }}
